<Window x:Class="Erosion3Tools.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Excel → JSON 工具"
        Width="420" Height="330"
        WindowStartupLocation="CenterScreen"
        Background="#2E2E2E"
        Foreground="#DDDDDD"
        FontFamily="Segoe UI"
        AllowsTransparency="False"
        WindowStyle="SingleBorderWindow"
        AllowDrop="True"
        Drop="Window_Drop">

    <Grid Margin="20" Background="#3A3A3A">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1*"/>
            <ColumnDefinition Width="1*"/>
        </Grid.ColumnDefinitions>

        <!-- 文件提示 -->
        <TextBlock x:Name="TxtTip"
                   Text="请拖入 .xlsx 文件"
                   FontSize="15"
                   FontWeight="Bold"
                   Grid.Row="0" Grid.ColumnSpan="2"
                   Margin="0,0,0,12"
                   HorizontalAlignment="Center"
                   Foreground="#E0E0E0"/>

        <!-- 转换类型 -->
        <TextBlock x:Name="ConvertTypeLabel"
                   Text="转换类型" Grid.Row="1" Grid.Column="0"
                   VerticalAlignment="Center"
                   HorizontalAlignment="Right"
                   Margin="0,0,8,8"
                   Foreground="#CCCCCC"/>

        <ComboBox x:Name="ConvertTypeComboBox"
                  Grid.Row="1" Grid.Column="1"
                  Margin="0,0,0,8"
                  Background="#4A4A4A"
                  Foreground="White"
                  BorderBrush="#5C5C5C"
                  Padding="4,2"
                  FontSize="14"
                  SelectionChanged="ConvertTypeComboBox_SelectionChanged"
                  SelectedIndex="0">
            <ComboBoxItem Content="地图数据"/>
            <ComboBoxItem Content="敌人数据"/>
        </ComboBox>

        <!-- 行数 -->
        <TextBlock x:Name="RowLabel" Text="行数" Grid.Row="2" Grid.Column="0"
                   VerticalAlignment="Center"
                   HorizontalAlignment="Right"
                   Margin="0,0,8,8"
                   Foreground="#CCCCCC"/>

        <TextBox x:Name="RowTextBox"
                 Grid.Row="2" Grid.Column="1"
                 Margin="0,0,0,8"
                 Background="#4A4A4A" 
                 Foreground="White"
                 BorderBrush="#5C5C5C"
                 Padding="4,2"
                 FontSize="16" 
                 VerticalContentAlignment="Center"
                 Text="15"/>

        <!-- 列数 -->
        <TextBlock x:Name="ColLabel" Text="列数" Grid.Row="3" Grid.Column="0"
                   VerticalAlignment="Center"
                   HorizontalAlignment="Right"
                   Margin="0,0,8,10"
                   Foreground="#CCCCCC"/>

        <TextBox x:Name="ColTextBox"
                 Grid.Row="3" Grid.Column="1"
                 Margin="0,0,0,10"
                 Background="#4A4A4A"
                 Foreground="White"
                 BorderBrush="#5C5C5C"
                 Padding="4,2"
                 FontSize="16"
                 VerticalContentAlignment="Center"
                 Text="15"/>

        <!-- 按钮 -->
        <Button Content="转换为 JSON"
                Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="2"
                Width="160" Height="36"
                Margin="0,10,0,0"
                HorizontalAlignment="Center"
                Background="#E67E22"
                Foreground="White"
                BorderThickness="0"
                FontWeight="Bold"
                Cursor="Hand"
                Click="Convert_Click">
            <Button.Style>
                <Style TargetType="Button">
                    <Setter Property="Background" Value="#E67E22"/>
                    <Setter Property="Foreground" Value="White"/>
                    <Setter Property="BorderBrush" Value="#E67E22"/>
                    <Setter Property="FontWeight" Value="Bold"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}"
                                        CornerRadius="3">
                                    <ContentPresenter
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" 
                                                Value="#F39C12"/>
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter Property="Background" 
                                                Value="#D35400"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </Button.Style>
        </Button>

        <!-- 底部提示 -->
        <TextBlock x:Name="BottomTipTextBlock"
                   Text="提示：行列数需与地图 Excel 表格一致"
                   Grid.Row="5" Grid.Column="0" Grid.ColumnSpan="2"
                   FontSize="11"
                   Foreground="#AAAAAA"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Top"
                   Margin="0,15,0,0"
                   TextAlignment="Center"/>
    </Grid>
</Window>
