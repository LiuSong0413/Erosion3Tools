<Window x:Class="Erosion3Tools.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Erosion3Tools"
        Width="520" Height="400"
        WindowStartupLocation="CenterScreen"
        Background="#1F232A"
        Foreground="#D4D7DC"
        FontFamily="Segoe UI"
        WindowStyle="SingleBorderWindow"
        AllowDrop="True"
        Drop="Window_Drop">

    <Window.Resources>
        <SolidColorBrush x:Key="PanelBrush" Color="#2A2F38"/>
        <SolidColorBrush x:Key="InputBrush" Color="#1C2027"/>
        <SolidColorBrush x:Key="BorderBrushDark" Color="#3C4552"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#F28B35"/>
        <SolidColorBrush x:Key="AccentHoverBrush" Color="#F7A85B"/>
        <SolidColorBrush x:Key="AccentPressedBrush" Color="#C76A1F"/>

        <Style x:Key="PanelLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#AEB7C2"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>

        <Style x:Key="InputTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="{StaticResource InputBrush}"/>
            <Setter Property="Foreground" Value="#E6E8EB"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushDark}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style x:Key="InputComboBox" TargetType="ComboBox">
            <Setter Property="Background" Value="{StaticResource InputBrush}"/>
            <Setter Property="Foreground" Value="#E6E8EB"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushDark}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border x:Name="MainBorder"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="3"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="32"/>
                                </Grid.ColumnDefinitions>
                                <ContentPresenter Grid.Column="0"
                                                  Margin="10,0,8,0"
                                                  VerticalAlignment="Center"
                                                  HorizontalAlignment="Left"
                                                  Content="{TemplateBinding SelectionBoxItem}"
                                                  ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                  ContentStringFormat="{TemplateBinding SelectionBoxItemStringFormat}"/>
                                <Border Grid.Column="1"
                                        Background="#252B34"
                                        BorderBrush="#465261"
                                        BorderThickness="1,0,0,0">
                                    <Path Width="10"
                                          Height="6"
                                          Stretch="Fill"
                                          Fill="#9FAAB8"
                                          Data="M 0 0 L 10 0 L 5 6 Z"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                                </Border>
                            </Grid>
                            <ToggleButton x:Name="DropDownToggle"
                                          Grid.ColumnSpan="2"
                                          Background="Transparent"
                                          BorderThickness="0"
                                          Focusable="False"
                                          IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"/>
                            <Popup x:Name="Popup"
                                   Placement="Bottom"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   PopupAnimation="Fade">
                                <Border MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                                        Background="#1C2027"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="3"
                                        Margin="0,4,0,0">
                                    <ScrollViewer MaxHeight="220">
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="MainBorder" Property="BorderBrush" Value="#556172"/>
                            </Trigger>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter TargetName="MainBorder" Property="BorderBrush" Value="#7A8798"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="InputComboBoxItem" TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="#E6E8EB"/>
            <Setter Property="Background" Value="#1C2027"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="ItemBorder"
                                Background="{TemplateBinding Background}">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#364050"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#4A5568"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
            <Setter Property="Foreground" Value="#F8F9FB"/>
            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource AccentHoverBrush}"/>
                                <Setter Property="BorderBrush" Value="{StaticResource AccentHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="{StaticResource AccentPressedBrush}"/>
                                <Setter Property="BorderBrush" Value="{StaticResource AccentPressedBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Border Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource BorderBrushDark}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="16">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock Text="Erosion3Tools"
                                   FontSize="19"
                                   FontWeight="SemiBold"
                                   Foreground="#E8EBF0"/>
                        <TextBlock Text="Excel 转 JSON"
                                   FontSize="12"
                                   Foreground="#909CAA"
                                   Margin="0,2,0,0"/>
                    </StackPanel>

                    <Border Grid.Column="1"
                            Background="#1A1E25"
                            BorderBrush="#2F3743"
                            BorderThickness="1"
                            CornerRadius="3"
                            Padding="8,4"
                            VerticalAlignment="Center">
                        <TextBlock Text=".xlsx"
                                   Foreground="#93A0B0"
                                   FontSize="12"
                                   FontWeight="SemiBold"/>
                    </Border>
                </Grid>

                <Border Grid.Row="1"
                        Margin="0,0,0,14"
                        Padding="12"
                        CornerRadius="5"
                        Background="#222833"
                        BorderBrush="#394352"
                        BorderThickness="1">
                    <TextBlock x:Name="TxtTip"
                               Text="请拖入 .xlsx 文件"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="#DDE2E8"
                               TextAlignment="Center"
                               HorizontalAlignment="Center"/>
                </Border>

                <Grid Grid.Row="2" Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="88"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="ConvertTypeLabel"
                               Grid.Column="0"
                               Text="转换类型"
                               Style="{StaticResource PanelLabel}"/>
                    <ComboBox x:Name="ConvertTypeComboBox"
                              Grid.Column="1"
                              Height="34"
                              Margin="0,0,0,6"
                              Style="{StaticResource InputComboBox}"
                              ItemContainerStyle="{StaticResource InputComboBoxItem}"
                              SelectionChanged="ConvertTypeComboBox_SelectionChanged"
                              SelectedIndex="0">
                        <ComboBoxItem Content="地图数据"/>
                        <ComboBoxItem Content="敌人数据"/>
                    </ComboBox>
                </Grid>

                <Grid Grid.Row="3" Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock x:Name="RowLabel" Text="行数" Style="{StaticResource PanelLabel}"/>
                        <TextBox x:Name="RowTextBox"
                                 Height="34"
                                 Style="{StaticResource InputTextBox}"
                                 Text="15"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock x:Name="ColLabel" Text="列数" Style="{StaticResource PanelLabel}"/>
                        <TextBox x:Name="ColTextBox"
                                 Height="34"
                                 Style="{StaticResource InputTextBox}"
                                 Text="15"/>
                    </StackPanel>
                </Grid>

                <StackPanel Grid.Row="4">
                    <Button Content="转换为 JSON"
                            Height="38"
                            Width="170"
                            HorizontalAlignment="Center"
                            Style="{StaticResource PrimaryButton}"
                            Click="Convert_Click"/>
                    <TextBlock x:Name="BottomTipTextBlock"
                               Text="提示：行列数需与地图 Excel 表格一致"
                               FontSize="12"
                               Foreground="#8E99A8"
                               HorizontalAlignment="Center"
                               Margin="0,12,0,0"
                               TextAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
